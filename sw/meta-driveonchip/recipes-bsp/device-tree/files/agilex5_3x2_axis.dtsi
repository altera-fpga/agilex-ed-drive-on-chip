/*
* Drive-on-Chip device tree fragment for Agilex 5
*/

/{
	soc@0 {
		doc0: doc0@40080000 {
			compatible = "generic-uio";
			reg = <0x40080000 0x108>,<0x40080108 0x108>,<0x40080210 0x108>,<0x40080318 0x108>;
			reg-names = "axis0","axis1","axis2","axis3";
		};

		doc1: doc1@40180000 {
			compatible = "generic-uio";
			reg = <0x40180000 0x108>,<0x40180108 0x108>,<0x40180210 0x108>,<0x40180318 0x108>;
			reg-names = "axis0","axis1","axis2","axis3";
		};
	};
};
